# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
ENV/
.env/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Unit test / coverage reports
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db

# Logs and databases
*.log
*.sqlite3

# Jupyter
.ipynb_checkpoints/

# Results / temporary outputs
results.csv
crops/
cropped_*.png
tmp/
*.tmp

# Paddle / PaddleX / ONNX artifacts and caches
.paddlex/
PaddleOCR_cache/
models/
__models__/
*.onnx
*.pdmodel
*.pdiparams
*.params
*.safetensors
*.bin

# Python bytecode
*.pyc

# Misc
*.swp
*~

# Secret envs
.env

# End of .gitignore
